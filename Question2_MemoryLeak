#include <Arduino.h>

// ==================== SENSOR DATA STRUCT ====================
struct SensorData {
  float temperature;
  float humidity;
  int light;
};

// ==================== FUNCTIONS ====================

// Old function (with memory leak) is now replaced
void readSensors(SensorData &data) {
  // Fill the existing struct instead of allocating new memory
  data.temperature = random(200, 300) / 10.0;  // 20.0 - 30.0 C
  data.humidity    = random(300, 600) / 10.0;  // 30% - 60%
  data.light       = random(0, 1024);          // Light sensor reading
}

// Print free heap memory for analysis
void printMemoryUsage(const char* label) {
  Serial.print(label);
  Serial.print(" - Free Heap: ");
  Serial.println(ESP.getFreeHeap());
}

// ==================== SETUP ====================
void setup() {
  Serial.begin(115200);
  while (!Serial);

  Serial.println("=== Memory Leak Analysis Demo ===");

  // Step 1: Show free memory at start
  printMemoryUsage("Start");

  // Step 2: Test reading sensors repeatedly
  SensorData sensor; // Stack-based allocation
  for (int i = 0; i < 5; i++) {
    readSensors(sensor);
    Serial.print("Reading ");
    Serial.print(i+1);
    Serial.print(" | Temp: ");
    Serial.print(sensor.temperature);
    Serial.print(" C, Hum: ");
    Serial.print(sensor.humidity);
    Serial.print(" %, Light: ");
    Serial.println(sensor.light);

    // Print memory after each reading
    printMemoryUsage("After reading");
    delay(500);
  }
}

void loop() {
  // Nothing to do
} // This is the group work
